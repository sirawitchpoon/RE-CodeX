# Re:CodeX — production .env (compose).
#
#   cp infra/compose/.env.example .env
#   # then edit and run:
#   docker compose --env-file .env -f infra/compose/docker-compose.yml up -d --build
#
# Keep this file out of git (it's already in .gitignore).

# ─── Caddy / public URL ────────────────────────────────────────────────────
# For LAN/dev:    CADDY_DOMAIN=:80
# For production: CADDY_DOMAIN=re-codex.example.com
CADDY_DOMAIN=:80

# Frontend → API base. Behind Caddy this is "/" (same origin).
PUBLIC_API_BASE=/
PUBLIC_BASE_URL=http://localhost

# ─── Discord ───────────────────────────────────────────────────────────────
GUILD_ID=
GUILD_NAME=Re:CodeX

GIVEAWAY_BOT_TOKEN=
GIVEAWAY_BOT_APP_ID=

LEVEL_BOT_TOKEN=
LEVEL_BOT_APP_ID=

# ─── Postgres (split: points-db = high-value, app-db = features) ──────────
POINTS_DB_NAME=recodex_points
POINTS_DB_USER=recodex_points
POINTS_DB_PASSWORD=change_me_points

APP_DB_NAME=recodex_app
APP_DB_USER=recodex_app
APP_DB_PASSWORD=change_me_app

# ─── Backoffice auth ───────────────────────────────────────────────────────
# JWT signing key. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_with_openssl_rand_hex_32
JWT_TTL_HOURS=24

# Used ONCE at boot time by the admin seed step (see README "Create the first
# admin user"). Leave blank in production after the first run; rotation is
# done by re-running the seed CLI from the host.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_8_chars_min

# ─── Misc ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
CORS_ORIGIN=*
