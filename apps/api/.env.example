# Re:CodeX API — copy to .env and fill in
# (POINTS_DATABASE_URL and APP_DATABASE_URL are required, all other keys have defaults)

NODE_ENV=development
API_PORT=3000
LOG_LEVEL=info

# Two separate Postgres containers per the points-isolation decision
# (points-data is the high-value volume; app-data holds giveaway/log/bot rows)
POINTS_DATABASE_URL=postgresql://recodex:devpw@localhost:5433/recodex_points?schema=public
APP_DATABASE_URL=postgresql://recodex:devpw@localhost:5434/recodex_app?schema=public

REDIS_URL=redis://localhost:6379

# Multer base directory; step 5 will write giveaway covers under
# ${UPLOADS_DIR}/giveaways/<id>.<ext>
UPLOADS_DIR=./data/uploads

# CORS — '*' is fine for LAN/dev mode; lock down before public deploy
CORS_ORIGIN=*
