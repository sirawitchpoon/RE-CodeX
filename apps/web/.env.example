# Base URL of the @recodex/api service. Behind Caddy in production this is
# usually `/` (same origin) or empty string. In dev where Vite is on :5173
# and the API is on :3000, set the absolute URL.
#
# When this is set, the SPA gates the whole app behind a username/password
# login (talks to POST /api/auth/login → JWT). Leaving it blank disables
# auth entirely so designers can preview the SPA without any backend.
VITE_API_BASE=http://localhost:3000

# Discord guild id this UI is administering. Used to scope leaderboard,
# level config, branding, dashboard requests.
VITE_GUILD_ID=
