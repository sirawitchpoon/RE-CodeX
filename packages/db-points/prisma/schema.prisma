// Re:CodeX — points-db
// HIGH-VALUE DATABASE. Owns Guild, User, BrandingConfig, LevelConfig,
// RoleReward, XpEvent, XpTotal. Migrations on app features must NEVER touch
// this database; rsync `points-data` volume independently for backups.

generator client {
  provider = "prisma-client-js"
  // Generate inside the package so a plain relative ESM import works.
  // ".prisma/points-client" was not a valid ESM specifier under Node's
  // strict resolver. The path is gitignored (packages/db-*/src/_prisma).
  output   = "../src/_prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POINTS_DATABASE_URL")
}

// ─── Discord mirrors (points-side) ────────────────────────────────────────────

model Guild {
  id        String   @id
  name      String
  createdAt DateTime @default(now())

  branding    BrandingConfig?
  levelConfig LevelConfig?
  roleRewards RoleReward[]
  xpTotals    XpTotal[]
  xpEvents    XpEvent[]
}

model User {
  id          String   @id
  username    String
  displayName String?
  avatarHash  String?
  createdAt   DateTime @default(now())

  xpTotals XpTotal[]
  xpEvents XpEvent[]
}

// ─── XP / Leveling ────────────────────────────────────────────────────────────

enum XpSource {
  TEXT
  VOICE
  REACTION
  STAGE
  STREAK
  MANUAL
}

model XpEvent {
  id        BigInt   @id @default(autoincrement())
  guildId   String
  userId    String
  source    XpSource
  amount    Int
  channelId String?
  messageId String?
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@index([guildId, channelId, createdAt])
}

model XpTotal {
  guildId       String
  userId        String
  totalXp       BigInt    @default(0)
  level         Int       @default(0)
  textXp        BigInt    @default(0)
  voiceXp       BigInt    @default(0)
  reactionXp    BigInt    @default(0)
  stageXp       BigInt    @default(0)
  streakDays    Int       @default(0)
  lastGrantAt   DateTime?
  voiceJoinedAt DateTime?
  updatedAt     DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([guildId, totalXp(sort: Desc)])
}

model LevelConfig {
  guildId          String   @id
  textEnabled      Boolean  @default(true)
  textMin          Int      @default(3)
  textMax          Int      @default(8)
  textCooldownSec  Int      @default(60)
  textMinChars     Int      @default(4)
  excludedChannels String[] @default([])
  voiceEnabled     Boolean  @default(true)
  voicePerMinute   Int      @default(1)
  reactionEnabled  Boolean  @default(true)
  reactionAmount   Int      @default(2)
  stageMultiplier  Int      @default(3)
  streakEnabled    Boolean  @default(false)
  streakBonus      Int      @default(50)
  curveLinear      Int      @default(1000)
  curveQuadratic   Int      @default(250)
  updatedAt        DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model RoleReward {
  id      String  @id @default(cuid())
  guildId String
  level   Int
  roleId  String
  hint    String?

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, level])
  @@index([guildId, level])
}

// ─── Branding (renamable labels) ──────────────────────────────────────────────

model BrandingConfig {
  guildId       String @id
  signalsLabel  String @default("Signals")
  xpLabel       String @default("EXP")
  currencyEmoji String @default("✨")
  accentColor   String @default("#c77dff")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}
