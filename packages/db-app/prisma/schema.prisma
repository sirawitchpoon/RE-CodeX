// Re:CodeX — app-db
// Owns Giveaway, GiveawayEntry, Log, BotInstance. References to User/Guild
// are SOFT FOREIGN KEYS (plain String columns) — the truth for those rows
// lives in `points-db` and joins are done in application code. This isolation
// is intentional: app-db schema migrations must never put points data at risk.

generator client {
  provider = "prisma-client-js"
  // Generate inside the package so a plain relative ESM import works.
  // ".prisma/app-client" was not a valid ESM specifier under Node's strict
  // resolver. The path is gitignored (packages/db-*/src/_prisma).
  output   = "../src/_prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("APP_DATABASE_URL")
}

// ─── Giveaways ────────────────────────────────────────────────────────────────

enum GiveawayStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

// Where the user prefers to be contacted if they win. DISCORD = use the
// userId mention; OTHER = arbitrary string the user typed in a modal.
enum ContactPreference {
  DISCORD
  OTHER
}

model Giveaway {
  id             String         @id @default(cuid())
  guildId        String         // soft FK → points-db Guild.id
  channelId      String
  channelName    String?        // resolved by bot on publish — for UI display
  title          String
  prize          String
  description    String?
  coverPath      String?
  requiredRoleId String?
  minLevel       Int            @default(0)
  winnersCount   Int            @default(1)
  status         GiveawayStatus @default(DRAFT)
  startsAt       DateTime?
  endsAt         DateTime?
  messageId      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  entries GiveawayEntry[]

  @@index([guildId, status, endsAt])
}

model GiveawayEntry {
  id           BigInt            @id @default(autoincrement())
  giveawayId   String
  userId       String             // soft FK → points-db User.id
  memberId     String             // soft FK → points-db GiveawayMember.id (the picked oshi)
  contactType  ContactPreference @default(DISCORD)
  contactValue String?            // null when DISCORD; required string when OTHER
  isWinner     Boolean            @default(false)
  createdAt    DateTime           @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, userId])
  @@index([giveawayId, createdAt])
  @@index([giveawayId, memberId])
}

// ─── Logs / observability ─────────────────────────────────────────────────────

enum LogLevel {
  INFO
  WARN
  ERROR
  EVENT
}

model Log {
  id        BigInt   @id @default(autoincrement())
  guildId   String?  // soft FK → points-db Guild.id
  level     LogLevel
  source    String
  event     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([level, createdAt])
}

model BotInstance {
  id            String   @id
  name          String
  status        String
  version       String
  startedAt     DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  cpuPct        Float?
  memMb         Int?
  eventCount    BigInt   @default(0)
}

// ─── Backoffice auth ──────────────────────────────────────────────────────────
// Admin users for the SPA. Lives in app-db (not points-db) because admin
// access lists are infrastructure / feature-adjacent — points-db stays
// strictly for XP data so backups don't conflate the two.

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}
